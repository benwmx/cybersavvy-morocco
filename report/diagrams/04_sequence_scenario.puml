@startuml sequence_scenario
skinparam backgroundColor #FFFFFF
skinparam defaultFontName Arial
skinparam sequenceArrowColor #0F3A6E
skinparam sequenceLifeLineBackgroundColor #EEF5FF
skinparam sequenceLifeLineBorderColor #0F3A6E
skinparam sequenceParticipantBackgroundColor #EEF5FF
skinparam sequenceParticipantBorderColor #0F3A6E
skinparam sequenceNoteBackgroundColor #FFFDE7
skinparam sequenceNoteBorderColor #F9A825

title Déroulement d'un scénario interactif (flux Élève)

actor "Élève" as S
participant "Application\n(React)" as App
database "IndexedDB\n(Dexie)" as IDB
database "Supabase\n(PostgreSQL)" as DB

== Identification de l'élève ==
S -> App : Saisit le code classe (6 car.)
App -> DB : verifyClassCode(code)\n→ récupère class_id
DB --> App : { class_id, class_name }

S -> App : Saisit le code Massar
App -> DB : verifyStudent(class_id, massar_code)
DB --> App : { student_id, name_fr, name_ar }
App -> App : Stocke session\n(localStorage)

== Chargement des scénarios ==
App -> DB : get_class_visible_scenarios(class_id)
DB --> App : Liste des scénarios visibles\n(title, description, image_url)
App --> IDB : syncPublicScenarios()\n(mise en cache locale)
App --> S : Affiche la liste des scénarios

== Jeu du scénario ==
S -> App : Sélectionne un scénario
App -> App : Charge questions[]\n(depuis cache ou Supabase)
App --> S : Affiche question 1\n(prompt + choix + média)

loop Pour chaque question du scénario
  S -> App : Sélectionne une réponse (index)
  App -> App : Compare avec correctIndex
  App --> S : Rétroaction immédiate :\n✓ Correct + explication\n✗ Incorrect + explication
  S -> App : Question suivante →
end

App -> App : Calcule score\n(correctes / total)
App --> S : Écran de résultats :\nscore, questions manquées

== Enregistrement du résultat ==
alt Mode connecté
  App -> DB : supabase.from("results").insert\n({ student_id, scenario_id, score, mistakes })
  DB --> App : { id, created_at }
else Mode hors-ligne
  App -> IDB : offline_queue.add\n({ result, synced: false })
  note right of IDB : Synchronisé automatiquement\nà la prochaine reconnexion
end

@enduml
