@startuml composants
skinparam backgroundColor #FFFFFF
skinparam defaultFontName Arial
skinparam class {
  BackgroundColor #EEF5FF
  BorderColor #0F3A6E
  FontColor #1A1A2E
  ArrowColor #0F3A6E
}
skinparam package {
  BackgroundColor #F8FBFF
  BorderColor #9CA3AF
  FontColor #374151
}

title Diagramme de composants — Architecture logicielle CyberSafe (frontend)

package "Contextes / Providers (état global)" {
  class LanguageContext {
    + lang : "fr" | "ar"
    + setLang(l: string) : void
    + t(key: string) : string
  }
  class StudentContext {
    + student : Student | null
    + login(classCode, massar) : Promise<void>
    + logout() : void
  }
  class OfflineSyncContext {
    + online : boolean
    + syncing : boolean
    - flushQueue() : Promise<void>
    - syncPublicScenarios() : Promise<void>
    - syncTranslations() : Promise<void>
  }
}

package "Couche API — api.ts (Supabase)" {
  class SupabaseAPI {
    -- Auth --
    + signIn(email, password)
    + signUp(email, password, meta)
    + signOut()
    + getSession()
    -- Classes / Élèves --
    + listMyClasses()
    + createClass(name)
    + deleteClass(id)
    + verifyClassCode(code)
    + verifyStudent(classId, massar)
    + addStudent(classId, ...)
    -- Scénarios --
    + listVisibleScenarios(classId)
    + getClassScenarioStatus(classId)
    + setScenarioVisibility(classId, scenId, visible)
    -- Résultats --
    + insertResult(studentId, scenId, score, mistakes)
    + listResultsWithStudents(classId)
    -- Admin (SECURITY DEFINER RPCs) --
    + adminSaveScenario(id, catId, title, desc, questions, imageUrl)
    + adminSaveCategory(id, name, color)
    + adminGetStats()
    + adminListUsers()
    -- Storage --
    + uploadMedia(userId, folder, file) : string
    + getMediaUrl(path) : string
  }
}

package "Base locale — Dexie (IndexedDB)" {
  class DexieDB {
    + offline_queue : Table<OfflineResult>
    + scenarios : Table<Scenario>
    + categories : Table<Category>
    + class_scenario_status : Table<CSS>
    + translations : Table<Translation>
  }
}

package "Hooks (logique métier)" {
  class useAuth {
    + session : Session | null
    + signIn(email, pass)
    + signOut()
  }
  class useGameData {
    + track : Scenario | null
    + saveResult(score, mistakes)
  }
  class useAnalytics {
    + results : ResultRow[]
    + statsPerScenario : ScenarioStat[]
  }
  class useStudentHistory {
    + history : Result[]
  }
}

package "Composants principaux (routes)" {
  class "game.tsx\n(Lobby élève)" as GameLobby {
    - Affiche scénarios assignés
    - Lecture IndexedDB si offline
  }
  class "game.$trackId.tsx\n(Lecteur de scénario)" as GamePlayer {
    - Gère progression Q/R
    - Affiche rétroaction immédiate
    - Appelle saveResult()
  }
  class "_authenticated/*\n(Espace enseignant)" as TeacherRoutes {
    - dashboard, classes
    - analytics, quizzes
  }
  class "admin/*\n(Panneau admin)" as AdminRoutes {
    - content editor (CRUD)
    - translations manager
    - users & classes list
  }
}

package "Composants réutilisables" {
  class ScenarioVisuals {
    + imageUrl : string | null
    + trackId : string
    + questionId : string
    -- affiche image/vidéo de couverture\nou placeholder générique --
  }
  class ImageUpload {
    + value : string | null
    + onChange(url: string | null)
    + userId : string
    + folder : "scenarios" | "questions"
    -- upload → Supabase Storage\nprévisualisation inline --
  }
}

' Dépendances
useAuth --> SupabaseAPI
useGameData --> SupabaseAPI
useGameData --> DexieDB
useAnalytics --> SupabaseAPI
useStudentHistory --> SupabaseAPI

OfflineSyncContext --> DexieDB
OfflineSyncContext --> SupabaseAPI

GameLobby --> useGameData
GameLobby --> StudentContext
GamePlayer --> useGameData
GamePlayer --> ScenarioVisuals
GamePlayer --> OfflineSyncContext

TeacherRoutes --> useAuth
TeacherRoutes --> useAnalytics
TeacherRoutes --> SupabaseAPI

AdminRoutes --> SupabaseAPI
AdminRoutes --> ImageUpload

ImageUpload --> SupabaseAPI : uploadMedia()
ScenarioVisuals --> ImageUpload : affiche media_url

GameLobby --> LanguageContext
GamePlayer --> LanguageContext
TeacherRoutes --> LanguageContext
AdminRoutes --> LanguageContext

@enduml
